---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/UI/header.astro";
import Footer from "../../components/UI/footer.astro";
import Knap from "../../components/UI/link.astro";
import CaseGif from "../../components/work/casegif.astro";
import Overskrift2 from "../../components/blocks/overskrift2.astro";
import Underoverskrift from "../../components/blocks/underoverskrift.astro";
import Display from "../../components/work/display.astro";
import Brodtekst from "../../components/blocks/brodtekst.astro";

import { casearray } from "../../scripts/casearray";

export async function getStaticPaths() {
  return casearray.map((c) => ({
    params: { slug: c.slug },
    props: { caseData: c },
  }));
}

const { caseData } = Astro.props;
const { titel, gif, text, imgdisplay, date, programs, url } = caseData;
---

<Layout>
  <Header titel={titel} />
  <div class="grid md:gap-25 gap-18">
    <CaseGif src={gif} alt={titel} />
    <div class="grid gap-10">
      <div>
        <Overskrift2 titel={titel} />
        <Underoverskrift>
          <h3 class="text-lg">{`> ${date}`}</h3>
          <h3 class="text-lg">{`> ${programs.join(", ")}`}</h3>
        </Underoverskrift>
      </div>

      <Brodtekst>{text.map((paragraph) => <p>{paragraph}</p>)}</Brodtekst>
      {
        url && (
          <div class="mx-auto max-w-7xl">
            <Knap url={url} tekst="see project" />
          </div>
        )
      }
    </div>

    <div class="grid gap-10">
      <div>
        <Overskrift2 titel="Fotos from the project" />
        <Underoverskrift>
          <h3 class="text-lg">{`> Selected images of the case`}</h3>
        </Underoverskrift>
      </div>
      <Display images={imgdisplay} />
    </div>
    <Footer />
  </div>
</Layout>
