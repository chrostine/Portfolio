---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/UI/footer.astro";
import Knap from "../components/UI/knap.astro";
import Figur from "../components/blocks/figur.astro";
import ShowWork from "../components/work/workshow.astro";
import Img from "../components/blocks/img.astro";
import Overskrift1 from "../components/blocks/overskrift1.astro";
import Underoverskrift from "../components/blocks/underoverskrift.astro";
import Brodtekst from "../components/blocks/brodtekst.astro";
import BrodtekstNoGap from "../components/blocks/brodtekst_nogap.astro";
import Streng from "../components/blocks/streng.astro";

import Sketch from "../components/sketch.astro";
---

<Layout>
  <div class="grid gap-25">
    <Sketch tekst="Christines portfolio" />
    <div class="mx-auto max-w-7xl grid text-center gap-5">
      <Streng />
      <div class="flex justify-center gap-1 sm:gap-5">
        <Knap tekst="about" />
        <Knap tekst="work" />
        <Knap tekst="contact" />
      </div>
    </div>
    <Img src="/assets/christine.png" />
    <div class="grid gap-10">
      <div id="about">
        <Overskrift1 titel="about" />
        <Underoverskrift>
          <h3 class="text-lg">{`> `}Hej, jeg hedder Christine</h3>
          <h3 class="text-lg">{`> `}Jeg er Coded Designer</h3>
        </Underoverskrift>
      </div>
      <Brodtekst>
        <p>
          Jeg er coded designer, og jeg arbejder med digitale oplevelser, hvor
          teknologi og kreativitet smelter sammen.
        </p>
        <p>
          Jeg har erfaring med at arbejde både alene og i tværfaglige teams. Jeg
          bliver især motiveret, når jeg kan være med til at omsætte idéer til
          noget, man kan interagere med og mærke, og jeg trives bedst i
          projekter, hvor jeg kan eksperimentere mig frem.
        </p>
        <p>
          For tiden er jeg optaget af interaktion og gamification som måder at
          skabe engagerende og meningsfulde digitale oplevelser.
        </p>
        <p>
          Jeg er altid åben for nye projekter og samarbejder - især dem, der
          udfordrer vante måder at bruge teknologi på.
        </p>
      </Brodtekst>
      <div class="py-10">
        <Figur />
      </div>
      <div class="grid gap-2">
        <Underoverskrift>
          <h3 class="text-lg">{`> `}Udannelse</h3>
        </Underoverskrift>
        <div class="grid gap-5">
          <BrodtekstNoGap aar="September 2024 - juni 2027">
            <p>Professionsbacheloruddannelse</p>
            <p>Visuel kommunikation, coded design</p>
            <p>Danmarks Medie- og Journalisthøjskole</p>
          </BrodtekstNoGap>
          <BrodtekstNoGap aar="Januar 2024 - juni 2024">
            <p>It-infrastruktur</p>
            <p>Københavns Universitet</p>
          </BrodtekstNoGap>
          <BrodtekstNoGap aar="Januar 2024 - juni 2024">
            <p>Empiriske undersøgelsesmetoder 1</p>
            <p>Københavns Universitet</p>
          </BrodtekstNoGap>
          <BrodtekstNoGap aar="September 2023 - januar 2024">
            <p>Grundlæggende datalogi</p>
            <p>Københavns Universitet</p>
          </BrodtekstNoGap>
          <BrodtekstNoGap aar="September 2023 - januar 2024">
            <p>Grundlæggende kommunikationsteori</p>
            <p>Københavns Universitet</p>
          </BrodtekstNoGap>
          <BrodtekstNoGap aar="Januar 2023 - juni 2023">
            <p>Formlab, glas og keramik</p>
            <p>Engelsholm Højskole</p>
          </BrodtekstNoGap>
        </div>
      </div>
    </div>

    <div id="work" class="grid gap-10">
      <div>
        <Overskrift1 titel="work" />
        <Underoverskrift>
          <h3 class="text-lg">
            {`> `}Arbejde, case studies og personlige projekter
          </h3>
        </Underoverskrift>
      </div>
      <ShowWork />
    </div>
    <div id="contact">
      <Footer />
    </div>
  </div>
</Layout>
