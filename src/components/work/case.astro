---
const { billede, href, titel, programmer } = Astro.props;

const ord = titel.split(" ");
const sidsteOrd = ord.pop();
const restenAfTitel = ord.join(" ");
---

<a href={href} class="group block h-[400px] w-[300px] shrink-0">
  <div
    class="h-full rounded-xl bg-center bg-no-repeat bg-cover grid items-end"
    style={`background-image: url(${billede})`}
  >
    <h3
      class="relative text-center
        bg-darkgrey text-blue text-sm px-5 py-2
        before:content-['>']
        before:opacity-0
        before:transition-opacity
        group-hover:before:opacity-100
        rounded-b-xl"
    >
      {restenAfTitel}{" "}
      <span
        class="inline-flex whitespace-nowrap
        after:content-['<'] after:pl-2
        after:opacity-0 after:transition-opacity
        group-hover:after:opacity-100"
      >
        {sidsteOrd}
      </span>
    </h3>
  </div>
</a>
