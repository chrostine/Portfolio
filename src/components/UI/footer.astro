---
import Some from "./some.astro";

let kontakt = "contact me >";
---

<div class="bg-green text-darkblue pt-5 pb-5">
  <div class="mx-auto max-w-7xl px-5 py-5 grid grid-cols-1 lg:grid-cols-3">
    <div
      class="flex gap-5 items-center flex-col text-5xl lg:col-span-2 lg:flex-row"
    >
      <h2>let's work together!</h2>
      <div class="wave-container text-xl">
        <h3 class="wave-text">
          {
            kontakt
              .split("")
              .map((bogstav, index) => (
                <span
                  style={`animation-delay: ${index * 0.2}s; margin-right: 0.07em;`}
                >
                  {bogstav === " " ? "\u00A0" : bogstav}
                </span>
              ))
          }
        </h3>
      </div>
    </div>

    <div
      class="flex items-center flex-col pt-5 lg:items-end lg:col-span-1 lg:pt-0"
    >
      <p>Christine Wrang Swierkosz</p>
      <p>christineswierkosz@outlook.dk</p>
      <p>2094 0242</p>
      <Some>
        <a
          href="https://dk.linkedin.com/in/christine-swierkosz-38359a289"
          target="_blank"
        >
          <img src="/assets/some/linkedin.png" class="h-full w-auto" />
        </a>
        <a href="https://github.com/chrostine" target="_blank">
          <img src="/assets/some/github.png" class="h-full w-auto" />
        </a>
        <a href="https://www.instagram.com/wrangstrik/" target="_blank">
          <img src="/assets/some/instagram.png" class="h-full w-auto" />
        </a>
      </Some>
    </div>
  </div>
</div>
