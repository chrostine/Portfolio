---
const { tekst } = Astro.props;
---

<div id="sketch" data-tekst={tekst}></div>

<script>
  import p5 from "p5";

  const sketchEl = document.getElementById("sketch");
  let tekst = (sketchEl?.dataset.tekst ?? "").toLowerCase();

  const root = getComputedStyle(document.documentElement);
  const darkblue = root.getPropertyValue("--color-darkblue").trim();
  const green = root.getPropertyValue("--color-green").trim();
  const hvid = root.getPropertyValue("--color-hvid").trim();
  const fontTitel = root.getPropertyValue("--font-titel").trim();
  const fontBrodtekst = root.getPropertyValue("--font-brodtekst").trim();
  const fontOverskrift = root.getPropertyValue("--font-overskrift").trim();
  const fontUnderoverskrift = root
    .getPropertyValue("--font-underoverskrift")
    .trim();

  // SKETCH START

  const sketch = (p: any) => {
    const getWidth = () => document.documentElement.clientWidth;
    const getHeight = () => document.documentElement.clientHeight;

    p.setup = () => {
      p.createCanvas(getWidth(), getHeight());
      p.textAlign(p.CENTER, p.CENTER);
    };

    p.draw = () => {
      p.background(darkblue);
      p.fill(hvid);
      p.noStroke();
      p.textFont(fontUnderoverskrift);
      p.textSize(15);
      p.text(tekst, p.width / 2, p.height / 2);
    };

    p.windowResized = () => {
      p.resizeCanvas(getWidth(), getHeight());
    };
  };

  new p5(sketch, document.getElementById("sketch") ?? undefined);

  // Lyt på ændringer fra streng.astro
  document.addEventListener("strengChanged", (e: Event) => {
    tekst = (e as CustomEvent).detail.toLowerCase();
  });
</script>
