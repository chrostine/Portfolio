---
const { tekst } = Astro.props;

import Underoverskrift from "./blocks/underoverskrift.astro";
---

<div class="relative">
  <div id="sketch" data-tekst={tekst}></div>
  <div
    class="absolute inset-0 flex flex-col gap-5 text-center text-green pt-50"
  >
    <div class="text-blue">
      <Underoverskrift>
        <h3>Welcome to</h3>
      </Underoverskrift>
    </div>
    <slot />
  </div>
</div>

<style>
  #sketch canvas {
    pointer-events: none;
  }
</style>

<script>
  import p5 from "p5";

  const sketchEl = document.getElementById("sketch");
  const gemt = sessionStorage.getItem("strengTekst");
  let tekst = (gemt ?? sketchEl?.dataset.tekst ?? "").toLowerCase();

  const root = getComputedStyle(document.documentElement);
  const darkblue = root.getPropertyValue("--color-darkblue").trim();
  const green = root.getPropertyValue("--color-green").trim();
  const blue = root.getPropertyValue("--color-blue").trim();
  const hvid = root.getPropertyValue("--color-hvid").trim();
  const fontTitel = root.getPropertyValue("--font-titel").trim();
  const fontBrodtekst = root.getPropertyValue("--font-brodtekst").trim();
  const fontOverskrift = root.getPropertyValue("--font-overskrift").trim();
  const fontUnderoverskrift = root
    .getPropertyValue("--font-underoverskrift")
    .trim();

  let phase = 0;
  let offset = 0;
  const frequency = 0.04;
  const amplitude = 70;

  let canWrite = false;

  // SKETCH START

  const sketch = (p: any) => {
    const getWidth = () => document.documentElement.clientWidth;
    const getHeight = () => document.documentElement.clientHeight;

    p.setup = () => {
      const canvas = p.createCanvas(getWidth(), getHeight());
      canvas.elt.style.pointerEvents = "none";
      canvas.elt.style.touchAction = "auto";
      p.textAlign(p.CENTER, p.CENTER);
    };

    p.draw = () => {
      p.background(darkblue);

      p.fill(green);
      p.noStroke();
      p.textFont(fontUnderoverskrift);
      p.textSize(16);

      // cursor
      p.push();
      p.fill(blue);
      p.noCursor();
      p.text(canWrite ? "write" : "scroll", p.mouseX, p.mouseY - 30);
      p.pop();

      // navigationspil
      p.push();
      p.translate(getWidth() / 2, getHeight() * 0.88);
      p.fill(blue);
      p.rotate(p.HALF_PI);
      p.textSize(60);
      p.text("_", -30, -21);
      p.text(">", 0, 0);
      p.pop();

      const letters = (tekst + " > ").split("");
      const letterSpacing = 15;
      const speed = 0.2;

      offset += speed;

      const shift = offset % letterSpacing;

      for (
        let i = -2;
        i * letterSpacing - shift < getWidth() + letterSpacing;
        i++
      ) {
        const x = i * letterSpacing - shift;
        const worldX = x + offset;

        const letterIndex =
          (((worldX / letterSpacing) % letters.length) + letters.length) %
          letters.length;
        const letter = letters[Math.floor(letterIndex)];

        const distFromCenter =
          0.2 - Math.abs((x - getWidth() / 2) / (getWidth() / 2));
        const variableAmplitude =
          amplitude * (0.1 + 0.9 * distFromCenter * distFromCenter);

        const y =
          getHeight() / 2 +
          variableAmplitude * p.sin(frequency * worldX + phase);

        p.text(letter, x, y);
      }

      phase += 0.02;
    };

    p.windowResized = () => {
      p.resizeCanvas(getWidth(), getHeight());
    };
  };

  new p5(sketch, document.getElementById("sketch") ?? undefined);

  // streng.astro
  document.addEventListener("strengChanged", (e: Event) => {
    tekst = (e as CustomEvent).detail.toLowerCase();
    sessionStorage.setItem("strengTekst", tekst);
  });

  document.addEventListener("mousemove", (e) => {
    const el = document.elementFromPoint(e.clientX, e.clientY);
    canWrite = el?.tagName === "INPUT" || el?.tagName === "TEXTAREA";
  });
</script>
